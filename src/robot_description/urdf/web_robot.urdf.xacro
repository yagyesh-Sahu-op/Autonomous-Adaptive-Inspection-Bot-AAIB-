<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="web_robot">

  <xacro:arg name="mesh_package" default="robot_description"/>
  <xacro:arg name="mesh_scale" default="0.1 0.1 0.1"/>
  <xacro:arg name="wheel_mass" default="0.25"/>
  <xacro:arg name="base_mass" default="2.0"/>
  <xacro:arg name="pi" default="3.141592653589793"/>
  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>
  <material name="white"><color rgba="1 1 1 1"/></material>
  <physics type="ode">
    <real_time_update_rate>100</real_time_update_rate>
  </physics>
    <!-- Define inertial property macros  -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}" iyz="0.0" izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy = "0" ixz = "0" iyy="${(m/12) * (3*r*r + h*h)}" iyz = "0" izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * m * (r*r)}" iyz="0.0" izz="${(2/5) * m * (r*r)}"/>
    </inertial>
  </xacro:macro>
  <xacro:macro name="base_link_macro" params="name">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0.0475"/>
        <geometry>
          <mesh filename="package://$(arg mesh_package)/meshes/base_link.dae" scale="$(arg mesh_scale)"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.0475"/>
        <geometry>
          <mesh filename="package://$(arg mesh_package)/meshes/base_link.dae" scale="$(arg mesh_scale)" />
        </geometry>
      </collision>
      <xacro:box_inertia m="$(arg base_mass)" w="0.16" h="0.2" d="0.03"/>
      <!-- <inertial>
        <mass value="$(arg base_mass)"/>
        <inertia ixx="0.0093" ixy="0.0" ixz="0.0"
                 iyy="0.0270" iyz="0.0" izz="0.0337"/>
      </inertial> -->
    </link>
  </xacro:macro>
  <!-- DRIVEN wheel macro (front wheels - high longitudinal grip) -->
<xacro:macro name="driven_wheel_macro" params="name rpy xyz">
  <link name="${name}">
    <visual>
      <origin rpy="${rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://$(arg mesh_package)/meshes/wheel.dae" scale="$(arg mesh_scale)"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="${rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://$(arg mesh_package)/meshes/wheel.dae" scale="$(arg mesh_scale)"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>       <!-- good forward grip -->
            <mu2>0.003</mu2>     <!-- some lateral resistance is OK for driven wheels -->
            <slip1>0.02</slip1>
            <slip2>1.0</slip2>
            
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>100000.0</kp>
            <kd>10.0</kd>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
    </collision>
    <xacro:cylinder_inertia m="$(arg wheel_mass)" r="0.054" h="0.02"/>
  </link>
  <joint name="${name}_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="${name}"/>
    <origin rpy="0 0 0" xyz="${xyz}"/>
  </joint>
  <transmission name="${name}_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="${name}_joint">
      <hardware_interface>hardware_interface/VelocityJointInterface</hardware_interface>
    </joint>
    <actuator name="${name}_motor">
      <hardware_interface>hardware_interface/VelocityJointInterface</hardware_interface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
</xacro:macro>

<!-- PASSIVE wheel macro (rear wheels - must slip laterally during rotation) -->
<xacro:macro name="passive_wheel_macro" params="name rpy xyz ">
  <link name="${name}">
    <visual>
      <origin rpy="${rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://$(arg mesh_package)/meshes/wheel.dae" scale="$(arg mesh_scale)"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="${rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://$(arg mesh_package)/meshes/wheel.dae" scale="$(arg mesh_scale)"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.5</mu>       <!-- some forward grip to follow the robot -->
            <mu2>0.01</mu2>    <!-- near-zero lateral friction = free sideways slip -->
            <slip1>0.002</slip1>
            <slip2>1.01</slip2> <!-- max lateral slip allowed -->
           
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>100000.0</kp>
            <kd>10.0</kd>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
      </surface>
    </collision>
    <xacro:cylinder_inertia m="$(arg wheel_mass)" r="0.054" h="0.02"/>
  </link>
  <joint name="${name}_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="${name}"/>
    <origin rpy="0 0 0" xyz="${xyz}"/>
  </joint>
  <transmission name="${name}_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="${name}_joint">
      <hardware_interface>hardware_interface/VelocityJointInterface</hardware_interface>
    </joint>
    <actuator name="${name}_motor">
      <hardware_interface>hardware_interface/VelocityJointInterface</hardware_interface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
</xacro:macro>
