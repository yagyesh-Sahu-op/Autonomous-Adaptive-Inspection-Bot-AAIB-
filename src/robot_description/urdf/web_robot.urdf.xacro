    </transmission>
  </xacro:macro> -->

  <xacro:base_link_macro name="base_link"/>

  <!-- Dummy footprint -->
  <link name="base_footprint"/>
  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  <link name="camera_cad">
    <visual>
      <geometry>
      <mesh filename="package://$(arg mesh_package)/meshes/camera.dae" scale="$(arg mesh_scale)" />
      </geometry>
    </visual>
  </link>
  <joint name="camera_cad_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_cad"/>
    <origin xyz="0.103 0 0.08" rpy="0 -0.17 0"/>
  </joint>

  <link name="top_cad">
    <visual>
      <geometry>
      <mesh filename="package://$(arg mesh_package)/meshes/top_cover.dae" scale="$(arg mesh_scale)" />
      </geometry>
    </visual>
  </link>
  <joint name="top_cover_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_cad"/>
    <origin xyz="0.1 0.07 0.09507" rpy="0 3.14 1.57075"/>
  </joint>

   <link name="lidar_cad">
    <visual>
      <geometry>
      <mesh filename="package://$(arg mesh_package)/meshes/lidar.dae" scale="$(arg mesh_scale)" />
      </geometry>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_cad"/>
    <origin xyz="0.0 -0.05 0.095" rpy="0 0 1.57075"/>
  </joint>

<!-- Front wheels: DRIVEN (controlled by diff_drive_controller) -->
<xacro:driven_wheel_macro  name="front_right_wheel" rpy="-1.57075 0 0" xyz="-0.069 -0.102 0.054"/>
<xacro:driven_wheel_macro  name="front_left_wheel"  rpy="1.57075 0 0"  xyz="-0.069 0.1 0.054"/>

<!-- Rear wheels: PASSIVE (free to slip sideways during turns) -->
<xacro:passive_wheel_macro name="back_right_wheel"  rpy="-1.57075 0 0" xyz="0.069 -0.102 0.054"/>
<xacro:passive_wheel_macro name="back_left_wheel"   rpy="1.57075 0 0"  xyz="0.069 0.1 0.054"/>
<!-- 
  <xacro:wheel_macro name="front_right_wheel" rpy="-1.57075 0 0" xyz="-0.069 -0.102 0.054"/>
  <xacro:wheel_macro name="front_left_wheel"  rpy="1.57075 0 0"  xyz="-0.069 0.1 0.054"/>
  <xacro:wheel_macro name="back_right_wheel"  rpy="-1.57075 0 0" xyz="0.069 -0.102 0.054"/>
  <xacro:wheel_macro name="back_left_wheel"   rpy="1.57075 0 0"  xyz="0.069 0.1 0.054"/> -->
  <!-- Right side wheels (rpy has -1.57) -->

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so" >
      <!-- <robot_param>robot_description</robot_param>
      <robotNamespace>web_robot</robotNamespace>
      <robotSimType>gazebo_ros2_control/GazeboSystem</robotSimType> -->
      <parameters>$(find robot_description)/config/diff_drive_controllers.yaml</parameters>
    </plugin>
    
  </gazebo>

  <ros2_control name="WebRobotSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="back_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="back_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo reference="front_right_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="front_left_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="back_right_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="back_left_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>

  <gazebo reference="camera_cad">
    <sensor name="camera" type="camera">
      
      <pose>0.1 0 0.98 0 -0.5 0</pose>
      <visualize>true</visualize>
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.05</near><far>8</far></clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>camera</namespace>
          <argument>--ros-args -r __ns:=camera</argument>
        </ros>
        <camera_name>camera_sensor</camera_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>


<link name="laser_link">
  <inertial>
    <mass value="0.01"/>
    <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
  </inertial>
  <visual>
    <geometry>
      <cylinder radius="0.01" length="0.01"/>
    </geometry>
    <material name="blue">
      <color rgba="0 0 1 1"/>
    </material>
  </visual>
</link>

<joint name="laser_joint" type="fixed">
  <parent link="base_link"/>
  <child link="laser_link"/>
 
<origin xyz="0 0 0.17" rpy="0 0 0"/> 
</joint>

<gazebo reference="laser_link">
  <sensor name="laser" type="ray">
    <pose>0 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>60.0</update_rate>
    <output_type>sensor_msgs/LaserScan</output_type>
    <ray>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1</resolution>
          <min_angle>-3.14</min_angle>
          <max_angle>3.14</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.1</min>
        <max>10.0</max>
        <resolution>0.01</resolution>
      </range>
    </ray>
    <plugin name="gazebo_ros_lidar_controller" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=scan_laser</remapping>
      </ros>
      <!-- <output_type>sensor_msgs/msg/LaserScan</output_type>
      <radiation_type>laser</radiation_type> -->
      <frame_name>laser_link</frame_name>
      <topic_name>scan_laser</topic_name> 
    </plugin>
  </sensor>
</gazebo>
<link name="imu_link">
  <visual>
    <geometry>
      <box size="0.03 0.02 0.01"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <box size="0.03 0.02 0.01"/>
    </geometry>
  </collision>

  <xacro:box_inertia m="0.1" w="0.1" d="0.1" h="0.1"/>
</link>

<joint name="imu_joint" type="fixed">
  <parent link="base_link"/>
  <child link="imu_link"/>
  <origin xyz="0 0 0.1"/>
</joint>

 <gazebo reference="imu_link">
  <sensor name="imu_sensor" type="imu">
   <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=imu</remapping>
      </ros>
      <initial_orientation_as_reference>false</initial_orientation_as_reference>
    </plugin>
    <always_on>true</always_on>
    <update_rate>100.0</update_rate>
    <visualize>true</visualize>
    <imu>
      <angular_velocity>
        <x>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean>
            <bias_stddev>0.0000008</bias_stddev>
          </noise>
        </x>
        <y>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean>
            <bias_stddev>0.0000008</bias_stddev>
          </noise>
        </y>
        <z>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean>
            <bias_stddev>0.0000008</bias_stddev>
          </noise>
        </z>
      </angular_velocity>
      <linear_acceleration>
        <x>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean>
            <bias_stddev>0.001</bias_stddev>
          </noise>
        </x>
        <y>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean>
            <bias_stddev>0.001</bias_stddev>
          </noise>
        </y>
        <z>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean>
            <bias_stddev>0.001</bias_stddev>
          </noise>
        </z>
      </linear_acceleration>
    </imu>
  </sensor>
</gazebo>

</robot>
