<?xml version="1.0"?>
<robot name="physics">

<material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/base_link.dae" />
      </geometry>
      <material name="blue"/>
    </visual>
      <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/base_link.dae" />
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>







    <link name="front_right_wheel">
    <visual>
    <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
      <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>


  <joint name="front_right_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin rpy="0 0 0" xyz="-0.69 -1.0 0.075"/>
  </joint>







    <link name="front_left_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>

      <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>


  <joint name="front_left_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.69 1.0 0.075"/>
  </joint>



    <link name="back_right_wheel">
    <visual>
    <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>

      <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
      <material name="black"/>
    </visual>
        <collision>
      <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>


  <joint name="back_right_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin rpy="0 0 0" xyz="0.69 -1.0 0.075"/>
  </joint>




    <link name="back_left_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>

      <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
      <material name="black"/>
    </visual>
        <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>


  <joint name="back_left_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin rpy="0 0 0" xyz="0.69 1.0 0.075"/>
  </joint>


</robot>