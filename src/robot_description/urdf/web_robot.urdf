<?xml version="1.0"?>
<robot name="web_robot">

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/base_link.dae" />
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/base_link.dae" /> 
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.0093" ixy="0.0" ixz="0.0" iyy="0.0270" iyz="0.0" izz="0.0337"/>
    </inertial>
  </link>

  <link name="base_footprint"/>
  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin rpy="-1.57075 0 0" xyz="0 0 0"/> 
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000125" ixy="0.0" ixz="0.0" iyy="0.000245" iyz="0.0" izz="0.000125"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin rpy="0 0 0" xyz="-0.69 -1.0 0.0"/>
  </joint>

  <link name="front_left_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000125" ixy="0.0" ixz="0.0" iyy="0.000245" iyz="0.0" izz="0.000125"/>
    </inertial>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.69 1.0 0.0"/>
  </joint>

  <link name="back_right_wheel">
    <visual>
      <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000125" ixy="0.0" ixz="0.0" iyy="0.000245" iyz="0.0" izz="0.000125"/>
    </inertial>
  </link>

  <joint name="back_right_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin rpy="0 0 0" xyz="0.69 -1.0 0.0"/>
  </joint>

  <link name="back_left_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/wheel.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000125" ixy="0.0" ixz="0.0" iyy="0.000245" iyz="0.0" izz="0.000125"/>
    </inertial>
  </link>

  <joint name="back_left_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin rpy="0 0 0" xyz="0.69 1.0 0.0"/>
  </joint>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_description_command>$(find xacro)/xacro $(arg model)</robot_description_command>
      <parameters>$(find robot_description)/config/diff_drive_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="front_left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="back_right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="back_left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="camera" type="camera">
      <pose>0.2 0 0.2 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>camera</namespace>
          <argument>--ros-args -r __ns:=camera</argument>
        </ros>
        <camera_name>camera_sensor</camera_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
